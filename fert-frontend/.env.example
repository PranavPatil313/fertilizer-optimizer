# Fertilizer Optimizer Frontend - Environment Variables
# Copy this file to .env and fill in the values

# ========== API Configuration ==========
# Backend API URL - Update this for cloud deployment
# For local development: http://localhost:8000
# For cloud deployment: https://your-backend-api.railway.app
VITE_API_BASE_URL=http://localhost:8000

# API Key for authentication (should match backend API_KEY)
VITE_API_KEY=supersecretapikey123

# ========== App Configuration ==========
VITE_APP_NAME=Fertilizer Optimizer
VITE_APP_VERSION=1.0.0

# ========== Feature Flags ==========
# Enable/disable features for mobile optimization
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_PWA=false
VITE_ENABLE_MOBILE_OPTIMIZATIONS=true

# ========== Analytics & Monitoring ==========
# Optional: Add analytics tracking IDs
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# ========== Development Only ==========
# These are for local development, not needed in production
PORT=5173
HOST=localhost
