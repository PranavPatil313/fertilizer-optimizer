# Fertilizer Optimizer - Environment Variables
# Copy this file to .env and fill in the values

# ========== Backend Configuration ==========
PORT=8000
ENV=production
DEBUG=false

# ========== Database Configuration ==========
# PostgreSQL Database URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://fert_user:fert_pass@localhost:5432/fertilizer_db

# ========== Authentication & Security ==========
# JWT Configuration
JWT_SECRET=replace_with_a_long_random_secret_please_minimum_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_SECRET=replace_with_another_strong_random_secret
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Security
API_KEY=supersecretapikey123
RATE_LIMIT=60/minute

# ========== CORS Configuration ==========
# For cloud deployment, add your frontend domain
# Separate multiple origins with commas
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend-domain.vercel.app

# ========== Weather API ==========
WEATHER_API_KEY=your_weather_api_key_here

# ========== Admin Configuration ==========
ADMIN_EMAILS=admin@example.com

# ========== Frontend Configuration ==========
VITE_API_BASE_URL=http://localhost:8000
VITE_API_KEY=supersecretapikey123

# ========== ML Model Configuration ==========
MODEL_VERSION=v1
MODEL_PATH=src/artifact/model.pkl
PREPROCESSOR_PATH=src/artifact/preprocessor.pkl
